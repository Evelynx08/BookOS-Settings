{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "identifier": "com.bookos.settings",
  "productName": "BookOS Settings",
  "version": "0.3.0",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "assetProtocol": {
        "scope": ["/**", "**"]
      },
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' asset: http://asset.localhost https://asset.localhost; img-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "Ajustes",
        "width": 1000,
        "height": 820,
        "minWidth": 720,
        "minHeight": 500,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "../src/assets/settings.png",
      "../src/assets/settings.svg"
    ],
    "targets": ["deb", "rpm"]
  }
}
